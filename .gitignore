PLAN.md
.DS_Store
node_modules/

# Provider-patch local deps
dotfiles/pi/.pi/agent/extensions/provider-patch/node_modules/

# npm lock file — machine-specific paths, managed by pi at runtime
dotfiles/pi/.pi/agent/npm/package-lock.json
dotfiles/pi/.pi/*/sessions/*
dotfiles/pi/.pi/*/auth*

# pi copy (never track)
dotfiles/pi copy/

# Broad safety net
**/auth.json
**/.pi/agent/sessions/
**/.pi/agent/stats.db*
**/.pi/agent/run-history.jsonl

# PI stats database
dotfiles/pi/.pi/agent/stats.db-wal
dotfiles/pi/.pi/agent/stats.db-shm
dotfiles/pi/.pi/agent/stats.db

# PI run history
dotfiles/pi/.pi/agent/run-history.jsonl
**/.pi/agent/*.log
