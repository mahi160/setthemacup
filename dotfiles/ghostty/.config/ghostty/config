# Eye-comfort themes (choose one)
theme = Everforest Dark Hard
# theme = Kanagawa Wave
# theme = Kanagawa Dragon
# theme = Gruvbox Material Dark
# theme = Nord
# theme = TokyoNight

# Available Everforest variants:
# - Everforest Dark Hard
# - Everforest Light Med

# Available Kanagawa variants:
# - Kanagawa Wave (default, warm)
# - Kanagawa Dragon (darker for late-night)
window-height = 24
window-width = 80
window-padding-x = 2
window-padding-balance = true
background-blur = true
background-opacity = 0.94
background-blur-radius = 140
# => === >=
# background = #1a1f26
# font-family = MonaspiceRn Nerd Font Propo
# font-family = BlexMono Nerd Font Mono
# font-family = VictorMono Nerd Font Propo
# font-family = Monaco
font-family = Maple Mono NF
font-size = 14
# font-thicken = true
# font-thicken-strength = 80
macos-titlebar-style = hidden
keybind = global:cmd+grave_accent=toggle_quick_terminal
title = " "
window-save-state = always
# adjust-cell-height = 10%
keybind = alt+left=unbind
keybind = alt+right=unbind
background-image = ~/Pictures/tbg.png
background-image-opacity = 0.15
background-image-position = bottom-right
