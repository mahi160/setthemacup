# theme = Gruvbox Material Dark
theme = Kanagawa Wave

# font-family = JetBrainsMono Nerd Font
font-family = Maple Mono NF
# font-family = JetBrains Mono
# font-family = Cascadia Code Mono
# font-family = MonaspiceRn Nerd Font Propo  # => === >=
# font-family = BlexMono Nerd Font Mono
# font-family = VictorMono Nerd Font Propo
# font-family = Monaco
font-size = 14
font-feature = +liga +calt +ss01 +ss02 +ss03



# Optional font adjustments:
# font-thicken = true
# font-thicken-strength = 80
# adjust-cell-height = 10%

# Window dimensions
window-height = 24
window-width = 80
window-padding-x = 2
window-padding-balance = true

background-blur = 240
background-opacity = 0.95

background-image = ~/Pictures/pokemon_bg/21.png
background-image-opacity = 0.15
background-image-fit = none
background-image-position = bottom-right

# Titlebar
macos-titlebar-style = hidden
title = " "

window-save-state = always
confirm-close-surface = false

shell-integration = detect
shell-integration-features = cursor,sudo,title
auto-update = check

cursor-style = block
cursor-style-blink = true

mouse-hide-while-typing = true
mouse-scroll-multiplier = 3

copy-on-select = clipboard

clipboard-read = ask
clipboard-write = allow

macos-option-as-alt = true

keybind = global:cmd+grave_accent=toggle_quick_terminal

keybind = alt+left=unbind
keybind = alt+right=unbind
