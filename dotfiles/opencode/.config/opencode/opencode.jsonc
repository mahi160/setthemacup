{
  "$schema": "https://opencode.ai/config.json",

  "model": "github-copilot/claude-sonnet-4.5",
  "small_model": "github-copilot/claude-haiku-4.5",
  "default_agent": "plan",
  "watcher": {
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/.next/**",
      "**/.nuxt/**",
      "**/coverage/**",
      "**/.git/**",
      "**/*.log",
      "**/tmp/**",
      "**/temp/**",
      "**/.cache/**",
      "**/.DS_Store",
      "**/package-lock.json",
      "**/yarn.lock",
      "**/pnpm-lock.yaml",
    ],
  },
}
